# Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control

# JWT Configuration
# Generate a strong secret key (at least 256 bits for HS256)
# You can generate one using: openssl rand -base64 32
JWT_SECRET=YourVerySecureSecretKeyThatIsAtLeast256BitsLongForHS256Algorithm
JWT_EXPIRATION=86400000

# Database Configuration (if using PostgreSQL in production)
# DB_URL=jdbc:postgresql://localhost:5432/customerdb
# DB_USERNAME=your_db_username
# DB_PASSWORD=your_db_password

# Server Configuration
# SERVER_PORT=8082
# GRPC_PORT=9091
